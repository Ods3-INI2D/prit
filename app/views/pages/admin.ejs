<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administrador - Painel de Controle</title>
    <link rel="stylesheet" href="/css/reset.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/admin-extended.css">
    <link rel="stylesheet" href="/css/theme.css">
    <script src="/js/theme.js"></script>
    <style>
        .categorias-grupo-admin {
            display: flex;
            flex-direction: column;
            gap: .6rem;
            margin-top: .5rem;
        }
        .checkbox-item-admin {
            display: flex;
            align-items: center;
            gap: .5rem;
        }
        .checkbox-input-admin {
            width: 1.1rem;
            height: 1.1rem;
            accent-color: #4da6ff;
            cursor: pointer;
        }
        .checkbox-label-admin {
            color: #d9d9d9;
            font-size: .95rem;
            cursor: pointer;
        }
        .adicionar-categoria {
            margin-bottom: 1rem;
        }
        @media (min-width: 901px) {
            .categorias-grupo-admin {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: .8rem;
            }
        }
    </style>
</head>
<body>
    <header>
        <img src="/imagens/logo.png" alt="Logotipo da Farmácia" class="logo">
        <h1 class="titulo">Painel Administrativo</h1>
    </header>
 
    <main>

        <% if (sucesso && mensagensSucesso[sucesso]) { %>
            <output class="mensagem-sucesso" role="status" aria-live="polite">
                <%= mensagensSucesso[sucesso] %>
            </output>
        <% } %>

        <% if (erro && erro === 'funcao_restrita') { %>
            <output class="mensagem-info" role="alert" aria-live="assertive">
                ⚠️ Esta funcionalidade está restrita a usuários clientes. Como administrador, você não pode acessar o carrinho ou avaliar produtos.
            </output>
        <% } else if (erro && mensagensErro[erro]) { %>
            <output class="mensagem-erro" role="alert" aria-live="assertive">
                <%= mensagensErro[erro] %>
            </output>
        <% } %>

        <section class="estatisticas" aria-labelledby="titulo-estatisticas">
            <h2 id="titulo-estatisticas" class="subtitulo">Estatísticas do Site</h2>
            <section class="estatisticas-grid">
                <article class="card-stats">
                    <h3 class="stat-titulo">Total de Produtos</h3>
                    <output class="stat-valor"><%= totalProdutos %></output>
                </article>
                <article class="card-stats">
                    <h3 class="stat-titulo">Total de Usuários</h3>
                    <output class="stat-valor"><%= usuarios.length %></output>
                </article>
                <article class="card-stats">
                    <h3 class="stat-titulo">Total de Categorias</h3>
                    <output class="stat-valor"><%= categorias.length %></output>
                </article>
            </section>
        </section>

        <section class="tabs-container">
            <nav class="tabs-header" role="tablist">
                <button class="tab-button active" data-tab="adicionar"   role="tab" aria-selected="true"  aria-controls="tab-adicionar">Adicionar Produto</button>
                <button class="tab-button"         data-tab="produtos"   role="tab" aria-selected="false" aria-controls="tab-produtos">Produtos</button>
                <button class="tab-button"         data-tab="categorias" role="tab" aria-selected="false" aria-controls="tab-categorias">Categorias</button>
                <button class="tab-button"         data-tab="usuarios"   role="tab" aria-selected="false" aria-controls="tab-usuarios">Usuários</button>
                <button class="tab-button"         data-tab="banners"    role="tab" aria-selected="false" aria-controls="tab-banners">Banners</button>
            </nav>

            <%# adicionar produto%>
            <article class="tab-content active" id="tab-adicionar" role="tabpanel" aria-labelledby="titulo-adicionar">
                <section class="adicionar-produto">
                    <h2 id="titulo-adicionar" class="subtitulo">Adicionar Novo Produto</h2>
                    
                    <form method="POST" action="/admin/adicionar-produto" class="form-produto" enctype="multipart/form-data" aria-label="Formulário de cadastro de produto">
                        <fieldset>
                            <legend class="label-titulo">Nome do Produto <output style="color:#ff6b6b">*</output></legend>
                            <label for="nome-add">
                                <input type="text" id="nome-add" name="nome" placeholder="Digite o nome do produto" required aria-required="true">
                            </label>
                        </fieldset>

                        <fieldset>
                            <legend class="label-titulo">Preço (R$) <output style="color:#ff6b6b">*</output></legend>
                            <label for="preco-add">
                                <input type="number" id="preco-add" name="preco" placeholder="0.00" step="0.01" min="0" required aria-required="true">
                            </label>
                        </fieldset>

                        <fieldset>
                            <legend class="label-titulo">Preço com Desconto (opcional)</legend>
                            <label for="precoDesconto-add">
                                <input type="number" id="precoDesconto-add" name="precoDesconto" placeholder="0.00" step="0.01" min="0">
                            </label>
                        </fieldset>

                        <fieldset>
                            <legend class="label-titulo">Categorias <output style="color:#ff6b6b">*</output> (selecione uma ou mais)</legend>
                            <% if (categorias && categorias.length > 0) { %>
                                <section class="categorias-grupo-admin">
                                    <% categorias.forEach(function(cat) { %>
                                        <label class="checkbox-item-admin">
                                            <input type="checkbox"
                                                   name="categorias"
                                                   value="<%= cat.id_categoria %>"
                                                   class="checkbox-input-admin">
                                            <output class="checkbox-label-admin"><%= cat.nome %></output>
                                        </label>
                                    <% }); %>
                                </section>
                            <% } else { %>
                                <output class="mensagem-info">Nenhuma categoria cadastrada. Crie categorias na aba "Categorias".</output>
                            <% } %>
                        </fieldset>

                        <fieldset>
                            <legend class="label-titulo">Status do Produto <output style="color:#ff6b6b">*</output></legend>
                            <label for="status-add">
                                <select id="status-add" name="status" required aria-required="true">
                                    <option value="em-estoque">Em Estoque</option>
                                    <option value="fora-de-estoque">Fora de Estoque</option>
                                </select>
                            </label>
                        </fieldset>

                        <fieldset class="campo-imagem">
                            <legend><strong class="label-titulo">Imagem do Produto</strong></legend>
                            <label for="imagem-add" class="label-arquivo">
                                <input type="file" id="imagem-add" name="imagem"
                                       accept="image/jpeg,image/jpg,image/png,image/webp"
                                       aria-describedby="imagem-add-info">
                                <output id="imagem-add-info" class="info-arquivo">Formatos aceitos: JPG, JPEG, PNG, WEBP (máx. 5MB)</output>
                            </label>
                            <output id="preview-imagem-add" class="preview-container" role="status" aria-live="polite"></output>
                        </fieldset>

                        <fieldset>
                            <legend class="label-titulo">Descrição do Produto <output style="color:#ff6b6b">*</output></legend>
                            <label for="descricao-add">
                                <textarea id="descricao-add" name="descricao" placeholder="Digite a descrição do produto" rows="5" required aria-required="true"></textarea>
                            </label>
                        </fieldset>

                        <button type="submit" class="btn-adicionar">Adicionar Produto</button>
                    </form>
                </section>
            </article>

            <%# produtos %>
            <article class="tab-content" id="tab-produtos" role="tabpanel" aria-labelledby="titulo-lista">
                <section class="lista-produtos">
                    <h2 id="titulo-lista" class="subtitulo">Produtos Cadastrados</h2>

                    <% if (produtos.length === 0) { %>
                        <output class="mensagem-vazia">Nenhum produto cadastrado ainda.</output>
                    <% } else { %>
                        <ul class="produtos-lista" role="list">
                            <% produtos.forEach(function(produto) { %>
                                <li class="produto-item" role="listitem">
                                    <article class="produto-info-container">
                                        <figure>
                                            <h3 class="produto-nome"><%= produto.nome %></h3>
                                            <figcaption class="produto-info">ID: <%= produto.id %></figcaption>
                                        </figure>
                                        <output class="produto-info">Categorias: <%= produto.categoria || 'Sem categoria' %></output>
                                        <output class="produto-info produto-preco">R$ <%= produto.preco.toFixed(2) %></output>
                                        <% if (produto.precoDesconto) { %>
                                            <output class="produto-info desconto">Com Desconto: R$ <%= produto.precoDesconto.toFixed(2) %></output>
                                        <% } %>
                                        <output class="produto-info <%= produto.status === 'em-estoque' ? '' : 'desconto' %>">
                                            Status: <%= produto.status === 'em-estoque' ? 'Em Estoque' : 'Fora de Estoque' %>
                                        </output>
                                    </article>
                                    <nav class="acoes-produto" aria-label="Ações do produto <%= produto.nome %>">
                                        <a href="/admin/editar-produto/<%= produto.id %>" class="btn-editar" aria-label="Editar produto <%= produto.nome %>">Editar</a>
                                        <form method="POST" action="/admin/excluir-produto/<%= produto.id %>" class="form-inline">
                                            <button class="btn-excluir" type="submit"
                                                    onclick="return confirm('Tem certeza que deseja excluir este produto?')"
                                                    aria-label="Excluir produto <%= produto.nome %>">Excluir</button>
                                        </form>
                                    </nav>
                                </li>
                            <% }); %>
                        </ul>
                    <% } %>
                </section>
            </article>

            <%# categorias%>
            <article class="tab-content" id="tab-categorias" role="tabpanel" aria-labelledby="titulo-categorias">
                <section class="lista-categorias-section">
                    <h2 id="titulo-categorias" class="subtitulo">Gerenciar Categorias</h2>

                    <section class="adicionar-categoria">
                        <h3 class="subtitulo" style="font-size:1.2rem;">Criar Nova Categoria</h3>
                        <form method="POST" action="/admin/criar-categoria" class="form-produto" aria-label="Formulário de criação de categoria">
                            <fieldset>
                                <legend class="label-titulo">Nome da Categoria <output style="color:#ff6b6b">*</output></legend>
                                <label for="nome_categoria">
                                    <input type="text" id="nome_categoria" name="nome_categoria"
                                           placeholder="Ex: Medicamentos, Bebê, Dermocosméticos..."
                                           required aria-required="true" minlength="2" maxlength="60">
                                </label>
                            </fieldset>
                            <button type="submit" class="btn-adicionar">Criar Categoria</button>
                        </form>
                    </section>

                    <% if (categorias && categorias.length > 0) { %>
                        <ul class="usuarios-lista" role="list" style="margin-top:2rem;">
                            <% categorias.forEach(function(cat) { %>
                                <li class="usuario-item" role="listitem">
                                    <article class="usuario-info-container">
                                        <figure>
                                            <h3 class="usuario-email"><%= cat.nome %></h3>
                                            <figcaption class="usuario-info">Slug: /categoria/<%= cat.slug %></figcaption>
                                        </figure>
                                    </article>
                                    <nav class="acoes-usuario" aria-label="Ações da categoria <%= cat.nome %>">
                                        <a href="/categoria/<%= cat.slug %>" class="btn-editar" target="_blank"
                                           aria-label="Ver página da categoria <%= cat.nome %>">Ver Página</a>
                                        <form method="POST" action="/admin/excluir-categoria/<%= cat.id_categoria %>" class="form-inline">
                                            <button class="btn-excluir" type="submit"
                                                    onclick="return confirm('Excluir categoria \'<%= cat.nome %>\'? Produtos vinculados perderão esta categoria.')"
                                                    aria-label="Excluir categoria <%= cat.nome %>">Excluir</button>
                                        </form>
                                    </nav>
                                </li>
                            <% }); %>
                        </ul>
                    <% } else { %>
                        <output class="mensagem-vazia" style="margin-top:1rem;">Nenhuma categoria cadastrada ainda.</output>
                    <% } %>
                </section>
            </article>

            <%# usuarios %>
            <article class="tab-content" id="tab-usuarios" role="tabpanel" aria-labelledby="titulo-usuarios">
                <section class="lista-usuarios-section">
                    <h2 id="titulo-usuarios" class="subtitulo">Usuários Cadastrados</h2>

                    <% if (usuarios.length === 0) { %>
                        <output class="mensagem-vazia">Nenhum usuário cadastrado ainda.</output>
                    <% } else { %>
                        <ul class="usuarios-lista" role="list">
                            <% usuarios.forEach(function(usuario) { %>
                                <li class="usuario-item" role="listitem">
                                    <article class="usuario-info-container">
                                        <figure>
                                            <h3 class="usuario-email"><%= usuario.email %></h3>
                                            <figcaption class="usuario-info">Nome: <%= usuario.nome %></figcaption>
                                        </figure>
                                        <output class="usuario-info">CPF: <%= usuario.cpf %></output>
                                        <output class="usuario-info">Telefone: (<%= usuario.ddd || '00' %>) <%= usuario.tel %></output>
                                        <time class="usuario-info" datetime="<%= usuario.nasc %>">
                                            Nascimento: <%= new Date(usuario.nasc).toLocaleDateString('pt-BR') %>
                                        </time>
                                    </article>
                                    <nav class="acoes-usuario" aria-label="Ações do usuário <%= usuario.email %>">
                                        <form method="POST" action="/admin/excluir-usuario/<%= encodeURIComponent(usuario.email) %>" class="form-inline">
                                            <button class="btn-excluir" type="submit"
                                                    onclick="return confirm('Tem certeza que deseja excluir este usuário?')"
                                                    aria-label="Excluir usuário <%= usuario.email %>">Excluir</button>
                                        </form>
                                    </nav>
                                </li>
                            <% }); %>
                        </ul>
                    <% } %>
                </section>
            </article>

            <%# banners %>
            <article class="tab-content" id="tab-banners" role="tabpanel" aria-labelledby="titulo-banners">
                <section class="lista-banners-section">
                    <h2 id="titulo-banners" class="subtitulo">Gerenciar Banners do Carrossel</h2>

                    <%# --- Formulário de criar novo banner --- %>
                    <section class="adicionar-categoria" style="margin-bottom:2rem;">
                        <h3 class="subtitulo" style="font-size:1.2rem;">Adicionar Novo Banner</h3>
                        <form method="POST" action="/admin/criar-banner" class="form-produto" enctype="multipart/form-data" aria-label="Formulário de criação de banner">
                            <fieldset>
                                <legend class="label-titulo">Legenda do Banner <output style="color:#ff6b6b">*</output></legend>
                                <label for="legenda-novo-banner">
                                    <input type="text" id="legenda-novo-banner" name="legenda"
                                           placeholder="Ex: Promoções de Verão"
                                           required aria-required="true" maxlength="150"
                                           aria-describedby="legenda-novo-info">
                                </label>
                                <output id="legenda-novo-info" class="info-arquivo">A legenda aparece sobreposta na imagem do banner.</output>
                            </fieldset>

                            <fieldset>
                                <legend class="label-titulo">Link de Destino</legend>
                                <label for="link-novo-banner">
                                    <input type="text" id="link-novo-banner" name="link"
                                           placeholder="/home ou /categoria/nome-da-categoria"
                                           aria-describedby="link-novo-info">
                                </label>
                                <output id="link-novo-info" class="info-arquivo">Exemplos: /home, /categoria/cuidados-com-a-pele, /produto/123</output>
                            </fieldset>

                            <fieldset class="campo-imagem">
                                <legend><strong class="label-titulo">Imagem do Banner <output style="color:#ff6b6b">*</output></strong></legend>
                                <label for="imagem-novo-banner" class="label-arquivo">
                                    <input type="file" id="imagem-novo-banner" name="imagem"
                                           accept="image/jpeg,image/jpg,image/png,image/webp"
                                           required aria-required="true"
                                           aria-describedby="imagem-novo-info">
                                    <output id="imagem-novo-info" class="info-arquivo">Formatos: JPG, PNG, WEBP (máx. 5MB). Recomendado: proporção 16:9.</output>
                                </label>
                                <output id="preview-novo-banner" class="preview-container" role="status" aria-live="polite"></output>
                            </fieldset>

                            <button type="submit" class="btn-adicionar">Adicionar Banner</button>
                        </form>
                    </section>

                    <%# --- Lista de banners existentes --- %>
                    <h3 class="subtitulo" style="font-size:1.2rem;">Banners Existentes</h3>

                    <output class="mensagem-info" role="status">
                        Edite ou exclua os banners que aparecem no carrossel da página inicial.
                    </output>

                    <% if (typeof banners !== 'undefined' && banners && banners.length > 0) { %>
                        <ul class="usuarios-lista" role="list">
                            <% banners.forEach(function(banner, index) { %>
                                <li class="usuario-item" role="listitem">
                                    <article class="usuario-info-container">
                                        <figure>
                                            <img src="<%= banner.imagem %>" alt="<%= banner.legenda %>"
                                                 style="max-width:200px;height:auto;border-radius:.5rem;margin-bottom:.5rem;">
                                            <figcaption class="usuario-info">Banner <%= index + 1 %></figcaption>
                                        </figure>
                                        <output class="usuario-info">Legenda: <%= banner.legenda %></output>
                                        <output class="usuario-info">Link: <%= banner.link || '/home' %></output>
                                    </article>
                                    <nav class="acoes-usuario" aria-label="Ações do banner <%= index + 1 %>">
                                        <button class="btn-editar" type="button"
                                                data-banner-id="<%= banner.id_banner %>"
                                                data-banner-legenda="<%= banner.legenda %>"
                                                data-banner-link="<%= banner.link || '/home' %>"
                                                aria-label="Editar banner <%= index + 1 %>">Editar</button>
                                        <form method="POST" action="/admin/excluir-banner/<%= banner.id_banner %>" class="form-inline">
                                            <button class="btn-excluir" type="submit"
                                                    onclick="return confirm('Tem certeza que deseja excluir este banner?')"
                                                    aria-label="Excluir banner <%= index + 1 %>">Excluir</button>
                                        </form>
                                    </nav>
                                </li>
                            <% }); %>
                        </ul>
                    <% } else { %>
                        <output class="mensagem-vazia">Nenhum banner cadastrado ainda. Adicione um acima!</output>
                    <% } %>
                </section>
            </article>
        </section>
    </main>
 
    <footer>
        <nav aria-label="Navegação do rodapé" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;padding:1rem 2%;">
            <a href="/home" class="link-footer">Voltar ao Site</a>
            <a href="/logout" class="link-footer" style="color:#ff6b6b;font-weight:600;">Sair da Conta de Administrador</a>
        </nav>
    </footer>

    <%# Modal de edição de banner %>
    <aside id="modal-banner" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-titulo">
        <article class="modal-content">
            <h2 class="subtitulo" id="modal-titulo">Editar Banner do Carrossel</h2>
            <form method="POST" id="form-editar-banner" enctype="multipart/form-data" class="form-produto" aria-label="Formulário de edição de banner">
                <fieldset>
                    <legend class="label-titulo">Legenda do Banner</legend>
                    <label for="legenda-banner">
                        <input type="text" id="legenda-banner" name="legenda"
                               placeholder="Ex: Promoções Especiais" required aria-required="true"
                               aria-describedby="legenda-info">
                    </label>
                    <output id="legenda-info" class="info-arquivo">A legenda aparecerá sobreposta na imagem do banner.</output>
                </fieldset>

                <fieldset>
                    <legend class="label-titulo">Link de Destino</legend>
                    <label for="link-banner">
                        <input type="text" id="link-banner" name="link"
                               placeholder="/home ou /categoria/nome" required aria-required="true"
                               aria-describedby="link-info">
                    </label>
                    <output id="link-info" class="info-arquivo">Exemplos: /home, /categoria/cuidados-com-a-pele, /produto/123</output>
                </fieldset>

                <fieldset class="campo-imagem">
                    <legend><strong class="label-titulo">Nova Imagem (opcional)</strong></legend>
                    <label for="imagem-banner" class="label-arquivo">
                        <input type="file" id="imagem-banner" name="imagem"
                               accept="image/jpeg,image/jpg,image/png,image/webp"
                               aria-describedby="banner-info">
                        <output id="banner-info" class="info-arquivo">
                            Formatos: JPG, PNG, WEBP (máx. 5MB). Deixe em branco para manter a imagem atual.
                        </output>
                    </label>
                    <output id="preview-banner" class="preview-container" role="status" aria-live="polite"></output>
                </fieldset>

                <button type="submit" class="btn-adicionar">Salvar Alterações do Banner</button>
                <button type="button" class="btn-adicionar" id="btn-fechar-modal"
                        style="background-color:#555;margin-top:1rem;">Cancelar</button>
            </form>
        </article>
    </aside>

    <script>
        document.addEventListener('DOMContentLoaded', function() {

            // tabs
            var tabButtons  = document.querySelectorAll('.tab-button');
            var tabContents = document.querySelectorAll('.tab-content');

            function ativarTab(tabId) {
                tabButtons.forEach(function(btn) {
                    btn.classList.remove('active');
                    btn.setAttribute('aria-selected', 'false');
                });
                tabContents.forEach(function(content) {
                    content.classList.remove('active');
                });
                var targetBtn = document.querySelector('[data-tab="' + tabId + '"]');
                var targetContent = document.getElementById('tab-' + tabId);
                if (targetBtn && targetContent) {
                    targetBtn.classList.add('active');
                    targetBtn.setAttribute('aria-selected', 'true');
                    targetContent.classList.add('active');
                }
            }

            tabButtons.forEach(function(button) {
                button.addEventListener('click', function() {
                    ativarTab(this.getAttribute('data-tab'));
                });
            });
            var params   = new URLSearchParams(window.location.search);
            var tabParam = params.get('tab');
            if (tabParam) {
                ativarTab(tabParam);
            }

            // preview da imagem
            function setupPreview(inputId, previewId, infoId) {
                var input   = document.getElementById(inputId);
                var preview = document.getElementById(previewId);
                var info    = infoId ? document.getElementById(infoId) : null;
                if (!input || !preview) return;

                input.addEventListener('change', function(e) {
                    var arquivo = e.target.files[0];
                    if (!arquivo) { preview.innerHTML = ''; return; }

                    if (arquivo.size > 5 * 1024 * 1024) {
                        if (info) { info.textContent = 'Erro: máximo 5MB'; info.style.color = '#d93025'; }
                        preview.innerHTML = ''; input.value = ''; return;
                    }
                    var tipos = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
                    if (!tipos.includes(arquivo.type)) {
                        if (info) { info.textContent = 'Erro: use JPG, PNG ou WEBP'; info.style.color = '#d93025'; }
                        preview.innerHTML = ''; input.value = ''; return;
                    }
                    var reader = new FileReader();
                    reader.onload = function(ev) {
                        var fig = document.createElement('figure');
                        fig.className = 'preview-figure';
                        var img = document.createElement('img');
                        img.src = ev.target.result; img.alt = 'Preview'; img.className = 'preview-img';
                        var cap = document.createElement('figcaption');
                        cap.textContent = arquivo.name; cap.className = 'preview-caption';
                        fig.appendChild(img); fig.appendChild(cap);
                        preview.innerHTML = ''; preview.appendChild(fig);
                        if (info) { info.textContent = 'Imagem selecionada!'; info.style.color = '#4da6ff'; }
                    };
                    reader.readAsDataURL(arquivo);
                });
            }

            setupPreview('imagem-add',        'preview-imagem-add',  'imagem-add-info');
            setupPreview('imagem-novo-banner', 'preview-novo-banner', 'imagem-novo-info');
            setupPreview('imagem-banner',      'preview-banner',      'banner-info');

            // ediçao de banner
            var modal        = document.getElementById('modal-banner');
            var form         = document.getElementById('form-editar-banner');
            var btnFechar    = document.getElementById('btn-fechar-modal');
            var inputLegenda = document.getElementById('legenda-banner');
            var inputLink    = document.getElementById('link-banner');

            function abrirModal(bannerId, legenda, link) {
                form.action = '/admin/editar-banner/' + bannerId;
                inputLegenda.value = legenda || '';
                inputLink.value    = link    || '/home';
                document.getElementById('imagem-banner').value = '';
                document.getElementById('preview-banner').innerHTML = '';
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';
                inputLegenda.focus();
            }

            function fecharModal() {
                form.reset();
                document.getElementById('preview-banner').innerHTML = '';
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }

            document.querySelectorAll('[data-banner-id]').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    abrirModal(
                        this.getAttribute('data-banner-id'),
                        this.getAttribute('data-banner-legenda'),
                        this.getAttribute('data-banner-link')
                    );
                });
            });

            if (btnFechar) btnFechar.addEventListener('click', fecharModal);
            if (modal)     modal.addEventListener('click', function(e) { if (e.target === modal) fecharModal(); });
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && modal && modal.classList.contains('active')) fecharModal();
            });
        });
    </script>
</body>
</html>